# Comma-separated list of allowed frontend origins (Render + Vercel URLs)
ALLOWED_ORIGINS=https://tradeski.onrender.com,https://tradeski.vercel.app

# Comma-separated list of stock symbols to track
STOCK_SYMBOLS=AAPL,MSFT,TSLA,NVDA,AMZN

# How often (in seconds) to fetch new prices
CHECK_INTERVAL=60

# Anthropic API key — required for Ski chatbot (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# FRED API key — required for macro ribbon and Ski macro context
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NewsAPI key — required for news sentiment panel and Ski news context
# Get a free key at https://newsapi.org/register (100 req/day free tier)
NEWS_API_KEY=

# Pushover push notifications (optional — leave blank to disable)
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# Railway injects PORT automatically — do not set this manually
# PORT=5000

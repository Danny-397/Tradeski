{
  "version": 2,
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/app", "dest": "/frontend/index.html" },
    { "src": "/", "dest": "/frontend/landing.html" },
    { "src": "/404", "dest": "/frontend/404.html" },
    { "src": "/(.*)", "dest": "/frontend/$1", "continue": true },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/404.html", "status": 404 }
  ]
}
